        </record>
        <record id="param_api_called" model="ir.config_parameter">
            <field name="key">odoo_allinoneaccessibility.api_called</field>
            <field name="value">False</field>
        </record>
        <record id="param_license_key" model="ir.config_parameter">
            <field name="key">odoo_allinoneaccessibility.license_key</field>
            <field name="value"></field>
        </record>

    </data>
</odoo>
