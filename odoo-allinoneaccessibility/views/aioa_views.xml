<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <data noupdate="0">

        <!-- ══ Default record created on install only, not overwritten on upgrade ══ -->
        <record id="aioa_settings_default" model="x_aioa.settings">
            <field name="x_name">Default</field>
            <field name="x_color_code">420083</field>
            <field name="x_style">bottom_left</field>
            <field name="x_icon_type">aioa-icon-type-1</field>
            <field name="x_icon_size_desktop">aioa-default-icon</field>
            <field name="x_size">regular</field>
        </record>
    </data>

    <data>

        <!-- ══ List View ══ -->
        <record id="view_aioa_settings_list" model="ir.ui.view">
            <field name="name">x_aioa.settings.list</field>
            <field name="model">x_aioa.settings</field>
            <field name="arch" type="xml">
                <list string="All in One Accessibility Settings">
                    <field name="x_color_code"/>
                    <field name="x_style"/>
                    <field name="x_icon_type"/>
                    <field name="x_size"/>
                </list>
            </field>
        </record>

        <!-- ══ Form View ══ -->
        <record id="view_aioa_settings_form" model="ir.ui.view">
            <field name="name">x_aioa.settings.form</field>
            <field name="model">x_aioa.settings</field>
            <field name="arch" type="xml">
                <form string="All in One Accessibility">
                    <header>
                        <button name="odoo-allinoneaccessibility.action_aioa_save_and_sync"
                                type="action"
                                string="Save and Sync Widget"
                                class="btn-primary"
                                save="1"/>
                    </header>
                    <sheet>

                        <group string="License &amp; Branding">
                            <group>
                                <field name="x_color_code"
                                       placeholder="420083"/>
                            </group>
                            <group>
                                <div class="text-muted">
                                    Enter hex color without the # symbol.<br/>
                                    Example: FF5733
                                </div>
                            </group>
                        </group>

                        <group string="Widget Position">
                            <group>
                                <field name="x_precise_position"/>
                                <field name="x_style"
                                       invisible="x_precise_position"/>
                                <field name="x_offset_right"
                                       invisible="not x_precise_position"/>
                                <field name="x_offset_right_dir"
                                       invisible="not x_precise_position"/>
                                <field name="x_offset_bottom"
                                       invisible="not x_precise_position"/>
                                <field name="x_offset_bottom_dir"
                                       invisible="not x_precise_position"/>
                            </group>
                        </group>

                        <group string="Widget &amp; Icon Appearance">
                            <group>
                                <field name="x_size"/>
                                <field name="x_icon_type"/>
                                <field name="x_custom_icon_size"/>
                                <field name="x_icon_size_desktop"
                                       invisible="x_custom_icon_size"/>
                                <field name="x_custom_icon_size_px"
                                       invisible="not x_custom_icon_size"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ══ Window Action ══ -->
        <record id="action_aioa_settings_window" model="ir.actions.act_window">
            <field name="name">All in One Accessibility</field>
            <field name="res_model">x_aioa.settings</field>
            <field name="view_mode">form,list</field>
            <field name="target">current</field>
        </record>
        
        <!-- ══ Inject into Odoo General Settings page ══ -->
        <record id="res_config_settings_view_aioa_inject" model="ir.ui.view">
            <field name="name">res.config.settings.view.aioa.inject</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@id='companies']" position="after">
                    <div id="aioa_settings_section" class="o_setting_box col-xs-12 col-md-6">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <div class="o_form_label">
                                <strong>All in One Accessibility</strong>
                            </div>
                            <div class="text-muted mt4 mb8">
                                Configure your accessibility widget — position, icon, color and license key.
                            </div>
                            <a type="action"
                               name="odoo-allinoneaccessibility.action_aioa_settings_window"
                               class="btn btn-secondary btn-sm"
                               role="button">
                                Configure Widget &#8594;
                            </a>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
